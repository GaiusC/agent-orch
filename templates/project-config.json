{
  "version": 1,
  "trusted": true,
  "roles": {
    "primary_writer": "cc",
    "specialist": "agy",
    "duplicate_implementation": false
  },
  "cli": {
    "claude": "claude",
    "agy": "agy",
    "claude_prefix_args": [],
    "agy_prefix_args": []
  },
  "execution": {
    "workspace_mode": "isolated",
    "allow_dirty_in_place": false,
    "max_cc_repair_rounds": 2,
    "cc_timeout_seconds": 1800,
    "agy_timeout_seconds": 900,
    "max_log_bytes": 4194304,
    "max_result_chars": 8000
  },
  "models": {
    "cc": {
      "low": null,
      "medium": null,
      "high": null
    },
    "agy": {
      "low": "Gemini 3.5 Flash (Medium)",
      "medium": "Gemini 3.1 Pro (Low)",
      "high": "Gemini 3.1 Pro (High)"
    }
  },
  "scope": {
    "writable": ["."],
    "forbidden": [".git/", ".env", ".env.*"]
  },
  "verification": {
    "commands": []
  }
}
